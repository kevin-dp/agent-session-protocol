{
  "name": "agent-session-protocol",
  "description": "Normalized format for agent coding sessions — and a reference CLI (`capi`) for sharing / resuming / tracking sessions across machines and agents (Claude Code, Codex).",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevin-dp/agent-session-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/kevin-dp/agent-session-protocol/issues"
  },
  "keywords": [
    "agent",
    "session",
    "protocol",
    "claude",
    "codex",
    "normalize",
    "capi",
    "share"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "bin": {
    "capi": "./bin/capi.mjs",
    "capi-queue-channel": "./bin/capi-queue-channel.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "dependencies": {
    "@durable-streams/client": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.3.0",
    "@types/node": "^22.15.21",
    "tsdown": "^0.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.2",
    "vitest": "^3.1.3"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:e2e": "tsx test/capi/e2e-phase1.ts && tsx test/capi/e2e-phase2.ts && tsx test/capi/e2e-phase4.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
